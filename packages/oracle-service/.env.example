# Starknet Sepolia RPC
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_9/YOUR_KEY

# Deployer account (must be owner of MockOracle)
ACCOUNT_ADDRESS=0x06957135613e700721fb095c5926163753d5d97e1b0183d40a9cce277aadd40c
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# MockOracle address (Starknet Sepolia)
MOCK_ORACLE_ADDRESS=0x04ed3d329fffa670f2a728444a9b53d0cae859a4397adfbde1622e0303041f14

# CDP stack addresses (optional; defaults are wired to current Sepolia deployment)
CDP_CORE_ADDRESS=0x070985a3cf9817e50a90bc2d3550f77d64f8a9bebc71577172295682f9580879
VAULT_REGISTRY_ADDRESS=0x0147864dd4a1c9849cbdaea58c22cdc36fe42a66c1102bc02ec4668932937bae

# CoinGecko Demo API key (optional — public endpoint works without it, but key gives higher rate limits)
COINGECKO_API_KEY=

# Price update interval in minutes (default: 5)
PRICE_UPDATE_INTERVAL=5

# Volatility update interval in minutes (default: 60)
VOLATILITY_UPDATE_INTERVAL=60

# Vault health monitor interval in minutes (default: 2)
HEALTH_CHECK_INTERVAL=2

# Bitcoin UTXO monitor interval in minutes (default: 2)
BTC_UTXO_CHECK_INTERVAL=2

# Optional Bitcoin Core RPC config for vault outpoint monitoring
BITCOIN_RPC_URL=http://127.0.0.1:18443
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
# Optional wallet endpoint suffix for RPC (if needed)
BITCOIN_RPC_WALLET=

# Optional comma-separated outpoints to monitor: txid:vout
MONITORED_BTC_OUTPOINTS=

# Optional comma-separated txids to monitor explicitly (64-char hex each)
MONITORED_TXIDS=

# Discover txids automatically from VaultRegistry events (default: true)
MONITOR_REGISTRY_EVENTS=true

# Automatically call CDPCore.liquidate(txid) when HF < 100 (default: false)
AUTO_LIQUIDATE=false

# Oracle attestation signer (stark curve private key)
ORACLE_ATTESTATION_PRIVATE_KEY=

# Output files (relative to oracle-service directory)
ATTESTATION_LOG_PATH=attestations.jsonl
ORACLE_STATE_PATH=.oracle-state.json
